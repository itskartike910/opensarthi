<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network: LLM API calls + localhost WebSocket -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Voice: microphone for STT via Android SpeechRecognizer -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Screen observation: for observe_screen tool via MediaProjection -->
    <!-- Note: MediaProjection requires user consent dialog at runtime -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Accessibility: for click/type automation tools -->
    <!-- Note: user must enable in Android Settings > Accessibility -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- Wake lock: keep CPU alive while running agent tasks -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibration: for haptic feedback on voice recognition -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".OpenSarthiApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenSarthi"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Python runtime foreground service (keeps it alive when app is backgrounded) -->
        <service
            android:name=".RuntimeService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

    </application>

</manifest>

#!/usr/bin/env bash
# Get the absolute path to this script's directory
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# 1. Resolve the runtime directory inside the AppImage or monorepo
if [ -d "/mnt/kartik/ai_desktop_agent_assistant/opensarthi/runtime" ]; then
    RUNTIME_DIR="/mnt/kartik/ai_desktop_agent_assistant/opensarthi/runtime"
elif [ -d "$SCRIPT_DIR/../lib/OpenSarthi/_up_/_up_/_up_/runtime" ]; then
    # Production AppImage directory path
    RUNTIME_DIR="$SCRIPT_DIR/../lib/OpenSarthi/_up_/_up_/_up_/runtime"
elif [ -d "$SCRIPT_DIR/resources/runtime" ]; then
    RUNTIME_DIR="$SCRIPT_DIR/resources/runtime"
elif [ -d "$SCRIPT_DIR/../resources/runtime" ]; then
    RUNTIME_DIR="$SCRIPT_DIR/../resources/runtime"
elif [ -d "$SCRIPT_DIR/../../../../../runtime" ]; then
    RUNTIME_DIR="$SCRIPT_DIR/../../../../../runtime"
else
    RUNTIME_DIR="$SCRIPT_DIR/../../../../runtime"
fi

# 2. Always use the user's home config venv (portable across machines)
USER_VENV_DIR="$HOME/.config/opensarthi"
USER_VENV="$USER_VENV_DIR/.venv"

# Check if a venv has all required packages
_check_venv() {
    local venv_python="$1/bin/python3"
    if [ -f "$venv_python" ]; then
        local err_msg
        err_msg=$(env -u LD_LIBRARY_PATH -u LD_PRELOAD "$venv_python" -c "import uvicorn, fastapi, speech_recognition" 2>&1)
        if [ $? -eq 0 ]; then
            return 0
        else
            echo "[SidecarWrapper] Venv check failed for $1: $err_msg" >&2
            return 1
        fi
    else
        echo "[SidecarWrapper] Venv python not found at $venv_python" >&2
        return 1
    fi
}

# Prefer runtime/.venv (dev) then user venv (production), then fallback to bootstrap
if _check_venv "$RUNTIME_DIR/.venv"; then
    ACTIVE_VENV="$RUNTIME_DIR/.venv"
elif _check_venv "$USER_VENV"; then
    ACTIVE_VENV="$USER_VENV"
else
    # Bootstrap: Create a fresh venv in the user's home config folder
    echo "Bootstrapping Python virtual environment inside $USER_VENV_DIR..."
    mkdir -p "$USER_VENV_DIR"
    
    # Find a working Python 3.10+
    PYTHON_BIN=""
    for py in python3.12 python3.11 python3.10 python3 /usr/bin/python3 /bin/python3 /opt/homebrew/bin/python3; do
        if env -u LD_LIBRARY_PATH "$py" -c "import sys; sys.exit(0 if sys.version_info >= (3,10) else 1)" 2>/dev/null; then
            PYTHON_BIN="$py"
            break
        fi
    done
    
    if [ -z "$PYTHON_BIN" ]; then
        echo "ERROR: Python 3.10+ not found on this system. Please install Python 3 first."
        exit 1
    fi
    
    env -u LD_LIBRARY_PATH "$PYTHON_BIN" -m venv "$USER_VENV"
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to create Python virtual environment."
        exit 1
    fi
    
    ACTIVE_VENV="$USER_VENV"
    
    # Activate and install sidecar dependencies
    source "$ACTIVE_VENV/bin/activate"
    env -u LD_LIBRARY_PATH pip install --upgrade pip --quiet
    if [ -f "$RUNTIME_DIR/requirements.txt" ]; then
        env -u LD_LIBRARY_PATH pip install -r "$RUNTIME_DIR/requirements.txt" --quiet
        echo "Dependencies installed successfully."
    else
        echo "WARNING: requirements.txt not found at $RUNTIME_DIR/requirements.txt"
    fi
fi

# 3. Activate the virtual environment
source "$ACTIVE_VENV/bin/activate"

# 4. Enter the resolved runtime directory and launch the backend
cd "$RUNTIME_DIR"
exec env -u LD_LIBRARY_PATH python main.py


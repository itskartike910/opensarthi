{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSarthi",
  "version": "0.1.0",
  "identifier": "dev.opensarthi.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build:vite"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenSarthi",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "alwaysOnTop": false,
        "transparent": true,
        "decorations": true,
        "skipTaskbar": false,
        "center": false,
        "x": null,
        "y": null,
        "visible": true,
        "focus": true,
        "shadow": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "tooltip": "OpenSarthi"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:* ws://localhost:* http://127.0.0.1:* http://localhost:*; script-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../../runtime/*.py",
      "../../../runtime/requirements.txt",
      "../../../runtime/api/**/*",
      "../../../runtime/planner/**/*",
      "../../../runtime/tools/**/*",
      "../../../runtime/voice/**/*"
    ],
    "externalBin": ["binaries/opensarthi-runtime"]
  }
}
